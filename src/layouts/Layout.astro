---
import "../styles/global.css";
const { title = "AuditPro" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body class="bg-gray-50 text-gray-900">
    <slot />
    <script type="module">
      import AOS from "aos";

      AOS.init({
        duration: 800,
        once: true,
      });
    </script>
   
  </body>
</html>
