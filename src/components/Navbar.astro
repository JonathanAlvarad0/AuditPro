---
// Puedes añadir lógica de Astro aquí si la necesitas
---

<nav class="fixed top-0 w-full bg-white/80 backdrop-blur-md shadow-sm z-50 border-b border-gray-100">
  <div class="max-w-6xl mx-auto flex justify-between items-center p-4">
    
    <a href="/" class="text-xl font-bold text-gray-800 hover:text-blue-600 transition-colors">
      AuditPro
    </a>

    <button 
      id="menu-btn"
      class="block md:hidden text-gray-600 focus:outline-none"
      aria-label="Abrir menú"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>

    <ul 
      id="menu-items" 
      class="hidden absolute md:static top-full left-0 w-full md:w-auto bg-white md:bg-transparent flex-col md:flex-row gap-6 p-6 md:p-0 shadow-lg md:shadow-none items-center text-gray-600 font-medium transition-all duration-300 md:flex"
    >
      <li><a href="#inicio" class="hover:text-blue-600 transition-colors">Inicio</a></li>
      <li><a href="#servicios" class="hover:text-blue-600 transition-colors">Servicios</a></li>
      <li><a href="#nosotros" class="hover:text-blue-600 transition-colors">Nosotros</a></li>
      <li><a href="#contacto" class="hover:text-blue-600 transition-colors">Contacto</a></li>
      
      <li class="md:hidden w-full">
        <a href="#contacto" class="block text-center bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700">
          Cotizar
        </a>
      </li>
    </ul>

    <div class="hidden md:block">
      <a href="#contacto" class="bg-blue-600 text-white px-5 py-2.5 rounded-lg hover:bg-blue-700 transition-all shadow-md active:scale-95">
        Cotizar
      </a>
    </div>

  </div>
</nav>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('menu-items');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
    menu?.classList.toggle('flex');
  });

  // Cerrar menú al hacer click en un enlace (ideal para Single Page)
  const links = menu?.querySelectorAll('a');
  links?.forEach(link => {
    link.addEventListener('click', () => {
      if (window.innerWidth < 768) { // Solo en móvil
        menu?.classList.add('hidden');
        menu?.classList.remove('flex');
      }
    });
  });
</script>s