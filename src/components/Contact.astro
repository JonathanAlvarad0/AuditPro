<section id="contacto" class="relative py-28 bg-white overflow-hidden">
  
  <div class="absolute top-0 right-0 w-[45%] h-full bg-slate-50 hidden lg:block"></div>

  <div class="relative max-w-[1300px] mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">

      <div class="relative order-2 md:order-1">
        <div data-aos="fade-right" class="mb-10">
          <div class="w-16 h-1.5 bg-blue-600 mb-8"></div>
          <span class="text-blue-600 font-black tracking-[0.5em] text-[11px] uppercase block mb-4">
            Direct Line
          </span>
          <h2 class="text-6xl lg:text-8xl font-black text-gray-900 leading-[0.85] tracking-tighter">
            Hablemos <br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-700 to-blue-500">
              de Negocios.
            </span>
          </h2>
        </div>

        <div class="space-y-8 max-w-md" data-aos="fade-up" data-aos-delay="200">
          <p class="text-xl text-gray-500 font-light leading-relaxed border-l-4 border-gray-100 pl-6">
            Transformamos la complejidad normativa en <span class="text-gray-900 font-bold italic">simplicidad operativa</span> para su empresa.
          </p>
          
          <div class="pt-6">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-4">Certificaciones & Ética</p>
            <div class="flex gap-4 opacity-50 grayscale hover:grayscale-0 transition-all">
                <div class="px-3 py-1 border border-gray-300 rounded text-[10px] font-bold uppercase">IFRS</div>
                <div class="px-3 py-1 border border-gray-300 rounded text-[10px] font-bold uppercase">Compliance</div>
                <div class="px-3 py-1 border border-gray-300 rounded text-[10px] font-bold uppercase">Audit PRO</div>
            </div>
          </div>
        </div>
      </div>

      <div class="relative order-1 md:order-2" data-aos="fade-left">
        
        <div class="relative group">
          
          <div class="absolute -inset-4 bg-blue-600/5 rounded-[3rem] blur-2xl group-hover:bg-blue-600/10 transition-colors"></div>

          <div class="relative bg-white border-[1px] border-gray-200 rounded-[2.5rem] p-8 lg:p-12 shadow-2xl overflow-hidden">
            
            <div class="absolute top-0 right-0 w-24 h-24 bg-blue-50/50 rounded-bl-[5rem] -z-10"></div>
            
            <div class="mb-10">
                <h3 class="text-2xl font-black text-gray-900 tracking-tight">Solicitud de Auditoría</h3>
                <p class="text-sm text-gray-400">Complete el formulario para recibir una propuesta técnica.</p>
            </div>

            <form class="space-y-6">
              <div class="group relative">
                <label class="text-[10px] font-bold text-blue-600 uppercase tracking-widest absolute -top-2 left-4 bg-white px-2 z-10">Nombre</label>
                <input 
                  type="text" 
                  class="w-full bg-transparent border-2 border-gray-100 rounded-2xl p-4 outline-none focus:border-blue-600 transition-all duration-300 text-gray-900 font-medium"
                  placeholder="Juan Pérez"
                />
              </div>

              <div class="group relative">
                <label class="text-[10px] font-bold text-blue-600 uppercase tracking-widest absolute -top-2 left-4 bg-white px-2 z-10">Email Corporativo</label>
                <input 
                  type="email" 
                  class="w-full bg-transparent border-2 border-gray-100 rounded-2xl p-4 outline-none focus:border-blue-600 transition-all duration-300 text-gray-900 font-medium"
                  placeholder="nombre@empresa.com"
                />
              </div>

              <div class="group relative">
                <label class="text-[10px] font-bold text-blue-600 uppercase tracking-widest absolute -top-2 left-4 bg-white px-2 z-10">Mensaje</label>
                <textarea 
                  rows="3" 
                  class="w-full bg-transparent border-2 border-gray-100 rounded-2xl p-4 outline-none focus:border-blue-600 transition-all duration-300 text-gray-900 font-medium resize-none"
                  placeholder="Describa brevemente su necesidad..."
                ></textarea>
              </div>

              <button 
                type="submit"
                class="w-full bg-blue-600 hover:bg-gray-900 text-white py-5 rounded-2xl font-bold tracking-widest uppercase text-sm shadow-xl shadow-blue-200 hover:shadow-gray-200 transition-all duration-500 transform active:scale-95"
              >
                Enviar Mensaje
              </button>
            </form>
          </div>
        </div>

        <div class="absolute -bottom-6 -right-6 w-20 h-20 bg-blue-600 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-pulse"></div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Asegura que el texto no se rompa de forma extraña */
  h2 {
    text-wrap: balance;
  }
</style>